{
  "openapi": "3.0.3",
  "info": {
    "title": "Mini ERP API",
    "version": "1.0.0",
    "description": "Import this file into Hoppscotch to test the Mini ERP backend endpoints."
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local backend default"
    },
    {
      "url": "http://localhost:5055",
      "description": "Local backend alternate if port 5000 is busy"
    }
  ],
  "tags": [
    {
      "name": "Health"
    },
    {
      "name": "Auth"
    },
    {
      "name": "Permissions"
    },
    {
      "name": "Customers"
    },
    {
      "name": "Vendors"
    },
    {
      "name": "Products"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Check API and MySQL health",
        "responses": {
          "200": {
            "description": "API and database are healthy",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessMessage"
                },
                "example": {
                  "success": true,
                  "message": "Mini ERP API and MySQL connection are healthy"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create a user",
        "description": "Admin role signup is blocked unless ALLOW_ADMIN_SIGNUP=true in the backend environment.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              },
              "example": {
                "login_id": "mahesh01",
                "email": "mahesh@example.com",
                "password": "Password@123",
                "full_name": "Mahesh Gupta",
                "address": "Colaba, Mumbai, 400001",
                "mobile_number": "+918000000000",
                "position": "Sales Manager",
                "role_codes": ["sales_user"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created and access token returned",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed"
          },
          "403": {
            "description": "Admin signup is disabled"
          },
          "409": {
            "description": "Login ID or email already exists"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "login_id": "mahesh01",
                "password": "Password@123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid Login Id or Password"
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get logged-in user profile",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logged-in user profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, expired, or inactive user token"
          }
        }
      }
    },
    "/api/permissions/metadata": {
      "get": {
        "tags": ["Permissions"],
        "summary": "List roles, modules, and actions",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Permission metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PermissionMetadataResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, expired, or inactive user token"
          }
        }
      }
    },
    "/api/permissions/me": {
      "get": {
        "tags": ["Permissions"],
        "summary": "Get logged-in user's module and field permissions",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Current user's permissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MyPermissionsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing, invalid, expired, or inactive user token"
          }
        }
      }
    },
    "/api/customers": {
      "get": {
        "tags": ["Customers"],
        "summary": "List customers",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/SearchQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": { "description": "Customer list" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      },
      "post": {
        "tags": ["Customers"],
        "summary": "Create customer",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" },
              "example": {
                "name": "Suzuki India",
                "address": "Mumbai, Maharashtra",
                "email": "purchase@suzuki.example",
                "mobile_number": "+918000000001"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Customer created" },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/customers/{id}": {
      "get": {
        "tags": ["Customers"],
        "summary": "Get customer",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Customer details" },
          "404": { "description": "Customer not found" }
        }
      },
      "patch": {
        "tags": ["Customers"],
        "summary": "Update customer",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" },
              "example": { "address": "Pune, Maharashtra" }
            }
          }
        },
        "responses": {
          "200": { "description": "Customer updated" },
          "400": { "description": "Validation failed" },
          "404": { "description": "Customer not found" }
        }
      },
      "delete": {
        "tags": ["Customers"],
        "summary": "Delete customer",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Customer deleted" },
          "404": { "description": "Customer not found" }
        }
      }
    },
    "/api/vendors": {
      "get": {
        "tags": ["Vendors"],
        "summary": "List vendors",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/SearchQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": { "description": "Vendor list" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      },
      "post": {
        "tags": ["Vendors"],
        "summary": "Create vendor",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" },
              "example": {
                "name": "Plastofact IN",
                "address": "Nashik, Maharashtra",
                "email": "sales@plastofact.example",
                "mobile_number": "+918000000002"
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Vendor created" },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/vendors/{id}": {
      "get": {
        "tags": ["Vendors"],
        "summary": "Get vendor",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Vendor details" },
          "404": { "description": "Vendor not found" }
        }
      },
      "patch": {
        "tags": ["Vendors"],
        "summary": "Update vendor",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ContactRequest" },
              "example": { "mobile_number": "+918000000099" }
            }
          }
        },
        "responses": {
          "200": { "description": "Vendor updated" },
          "400": { "description": "Validation failed" },
          "404": { "description": "Vendor not found" }
        }
      },
      "delete": {
        "tags": ["Vendors"],
        "summary": "Delete vendor",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Vendor deleted" },
          "404": { "description": "Vendor not found" }
        }
      }
    },
    "/api/products": {
      "get": {
        "tags": ["Products"],
        "summary": "List products",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "$ref": "#/components/parameters/SearchQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/OffsetQuery" }
        ],
        "responses": {
          "200": { "description": "Product list" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      },
      "post": {
        "tags": ["Products"],
        "summary": "Create product",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductRequest" },
              "example": {
                "name": "Lighting Frame",
                "sales_price": 10,
                "cost_price": 8,
                "on_hand_qty": 50,
                "procure_on_demand": false
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Product created" },
          "400": { "description": "Validation failed" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "tags": ["Products"],
        "summary": "Get product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Product details" },
          "404": { "description": "Product not found" }
        }
      },
      "patch": {
        "tags": ["Products"],
        "summary": "Update product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProductRequest" },
              "example": { "sales_price": 12, "cost_price": 9 }
            }
          }
        },
        "responses": {
          "200": { "description": "Product updated" },
          "400": { "description": "Validation failed" },
          "404": { "description": "Product not found" }
        }
      },
      "delete": {
        "tags": ["Products"],
        "summary": "Delete product",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "$ref": "#/components/parameters/IdPath" }],
        "responses": {
          "200": { "description": "Product deleted" },
          "404": { "description": "Product not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer",
          "minimum": 1
        }
      },
      "SearchQuery": {
        "name": "search",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 50,
          "maximum": 200
        }
      },
      "OffsetQuery": {
        "name": "offset",
        "in": "query",
        "required": false,
        "schema": {
          "type": "integer",
          "default": 0,
          "minimum": 0
        }
      }
    },
    "schemas": {
      "SuccessMessage": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "SignupRequest": {
        "type": "object",
        "required": ["login_id", "email", "password", "full_name"],
        "properties": {
          "login_id": {
            "type": "string",
            "minLength": 6,
            "maxLength": 12
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 9
          },
          "full_name": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "mobile_number": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "role_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "example": "sales_user"
            }
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["login_id", "password"],
        "properties": {
          "login_id": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "ContactRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 150
          },
          "address": {
            "type": "string",
            "nullable": true,
            "maxLength": 255
          },
          "email": {
            "type": "string",
            "format": "email",
            "nullable": true
          },
          "mobile_number": {
            "type": "string",
            "nullable": true,
            "maxLength": 20
          }
        }
      },
      "ProductRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 150
          },
          "sales_price": {
            "type": "number",
            "minimum": 0
          },
          "cost_price": {
            "type": "number",
            "minimum": 0
          },
          "on_hand_qty": {
            "type": "number",
            "minimum": 0
          },
          "procure_on_demand": {
            "type": "boolean"
          },
          "procurement_method": {
            "type": "string",
            "nullable": true,
            "enum": ["purchase", "manufacturing"]
          },
          "vendor_id": {
            "type": "integer",
            "nullable": true
          },
          "bom_id": {
            "type": "integer",
            "nullable": true
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/PublicUser"
              },
              "access_token": {
                "type": "string"
              }
            }
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/PublicUser"
              }
            }
          }
        }
      },
      "PublicUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "login_id": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "full_name": {
            "type": "string"
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "mobile_number": {
            "type": "string",
            "nullable": true
          },
          "position": {
            "type": "string",
            "nullable": true
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "PermissionMetadataResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "roles": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "modules": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      },
      "MyPermissionsResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "data": {
            "type": "object",
            "properties": {
              "roles": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "module_permissions": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "field_permissions": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  }
}
